# ============ 数据库 (PostgreSQL) ============
# 个人 Demo 推荐：Neon 免费层 https://neon.tech
# 本地开发：Docker 或 Neon
# 生产：Azure PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/tireops"

# ============ 认证 (NextAuth.js) ============
# 生成方式: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-at-least-32-chars"

# ============ AI (OpenAI) ============
# 可选，未配置时 AI 模块返回模拟结果
OPENAI_API_KEY="sk-your-key-here"

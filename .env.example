# ============ Database (PostgreSQL) ============
# Free demo: Neon https://neon.tech | Local: Docker or Neon | Production: Azure PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/tireops"

# ============ Auth (NextAuth.js) ============
# Generate: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-at-least-32-chars"

# ============ AI (OpenAI) ============
# Optional - AI modules return mock results if not set
OPENAI_API_KEY="sk-your-key-here"
